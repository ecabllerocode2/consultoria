# ============================================================
#  CURP Bot — Variables de Entorno
#  Copia este archivo como .env y completa los valores.
#  NUNCA subas el archivo .env al repositorio.
# ============================================================

# ------------------------------------------------------------
# Firebase Admin SDK
# ------------------------------------------------------------

# ID del proyecto Firebase (ej: mi-proyecto-12345)
FIREBASE_PROJECT_ID=

# Ruta relativa al archivo JSON de la cuenta de servicio.
# Descárgalo en: Firebase Console → Configuración del proyecto
# → Cuentas de servicio → Generar nueva clave privada
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccount.json

# ------------------------------------------------------------
# Cloudflare R2 (S3 API compatible)
# ------------------------------------------------------------

# Endpoint del bucket. Formato:
# https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=

# Credenciales generadas en:
# Cloudflare Dashboard → R2 → Manage R2 API tokens
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Nombre del bucket creado en R2
R2_BUCKET_NAME=curp-pdfs

# ------------------------------------------------------------
# Firebase Cloud Messaging (FCM)
# ------------------------------------------------------------

# Clave del servidor FCM. Obtenla en:
# Firebase Console → Configuración del proyecto → Cloud Messaging
# → API de Cloud Messaging (heredada) → Clave del servidor
FCM_SERVER_KEY=

# Token del dispositivo que recibirá las alertas push.
# Se obtiene desde la PWA una vez configurada (Fase 6).
# Por ahora puede dejarse vacío; el bot omitirá el envío de notificaciones.
FCM_DEVICE_TOKEN=
